  "values": [
    {
      "key": "accountability",
      "title": "Accountability",
      "iconSrc": "/vectors/about/business-deal.svg",
      "body": "We are accountable to each other and to those we serve. We follow through, own our outcomes, and hold ourselves to a higher standard.",
      "why": "Why it matters: students rely on us. Showing up means doing what we say we will, every time."
    },
    {
      "key": "integrity",
      "title": "Integrity",
      "iconSrc": "/vectors/about/growth.svg",
      "body": "We act with honesty and consistency, especially when no one is watching. Our word and our work line up.",
      "why": "Why it matters: trust is earned in small, daily decisions — and it is the foundation of everything else."
    },
    {
      "key": "innovation",
      "title": "Innovation",
      "iconSrc": "/vectors/about/upgrade.svg",
      "body": "We try things, learn quickly, and keep improving. We invite new ideas in and reshape what is possible for student life.",
      "why": "Why it matters: campus needs change every year. Standing still is not an option."
    },
    {
      "key": "community",
      "title": "Community",
      "iconSrc": "/vectors/about/community.svg",
      "body": "We identify the unique needs of our community and intentionally create a culture of belonging for every Golden Eagle.",
      "why": "Why it matters: nobody soars alone. The U-SU is at its best when every student feels at home."
    },
    {
      "key": "fun",
      "title": "Fun",
      "iconSrc": "/vectors/about/fireworks.svg",
      "body": "We enjoy what we do, sharing joy and passion to instill a fun, welcoming environment for students and staff alike.",
      "why": "Why it matters: college is short. Memorable moments make the work meaningful for everyone involved."
    },
    {
      "key": "connection",
      "title": "Connection",
      "iconSrc": "/vectors/about/connection.svg",
      "body": "We prioritize genuine connections, appreciating the unique value in each other and the people we serve.",
      "why": "Why it matters: relationships outlast roles. Strong connections turn coworkers into mentors and friends."
    }
  ],
  "current": {
    "departmentWinners": [
      {
        "id": "d1",
        "name": "Maya Hernandez",
        "dept": "Graffix",
        "deptKey": "graffix",
        "role": "Senior Designer",
        "quote": "Maya redesigned the U-SU’s entire event-poster system this year, cutting turnaround time in half while raising the visual bar across every department. Her calm leadership in the studio is the reason newer designers feel safe to take creative risks."
      },
      {
        "id": "d2",
        "name": "Jordan Okafor",
        "dept": "Cross Cultural Centers",
        "deptKey": "ccc",
        "role": "PASRC Programming Lead",
        "quote": "Jordan led Heritage Showcase from a quiet studio session into a 400-person sold-out event in the LA Room. Beyond the numbers, every PASRC student who walked in left feeling seen — and that is the harder, more important win."
      },
      {
        "id": "d3",
        "name": "Priya Ramesh",
        "dept": "Center for Student Involvement",
        "deptKey": "csi",
        "role": "Clubs & Orgs Coordinator",
        "quote": "Priya rebuilt the club registration flow from the ground up, onboarded 38 new student orgs, and somehow made paperwork feel like hospitality. She is the reason CSI is the friendliest desk on campus."
      },
      {
        "id": "d4",
        "name": "Marcus Bell",
        "dept": "Operations",
        "deptKey": "operations",
        "role": "Reservations Specialist",
        "quote": "Marcus handles 200+ room reservations a month with a level of care most companies could only dream of. When the boardroom A/V went down 20 minutes before a senate meeting, he had a backup running before anyone noticed."
      },
      {
        "id": "d5",
        "name": "Sofia Cabrera",
        "dept": "Recreation",
        "deptKey": "recreation",
        "role": "GENE Program Lead",
        "quote": "Sofia turned the Game Room from a quiet study spot into the most-loved hangout on the third floor. Her tournaments brought in students who had never set foot in the U-SU before — and many of them now work for us."
      },
      {
        "id": "d6",
        "name": "Aaron Whitaker",
        "dept": "Admin",
        "deptKey": "admin",
        "role": "Executive Office Assistant",
        "quote": "Aaron keeps the Executive Office running with a quiet competence that makes everyone else’s job possible. He notices what others miss — and the U-SU is steadier because of it."
      }
    ],
    "valueWinners": [
      {
        "id": "v1",
        "name": "Daniela Vargas",
        "value": "Accountability",
        "dept": "Operations",
        "deptKey": "operations",
        "role": "Building Manager, Evenings",
        "quote": "Daniela owns the night shift. When something goes wrong on a Tuesday at 9:47 PM, she is the one who finds the right person, files the right ticket, and stays until it is fixed. Accountability lives at her front desk."
      },
      {
        "id": "v2",
        "name": "Elijah Park",
        "value": "Integrity",
        "dept": "Center for Student Involvement",
        "deptKey": "csi",
        "role": "Fraternity & Sorority Life Mentor",
        "quote": "Elijah said the hard thing this year, more than once, when it would have been easier to stay quiet. He held his peers to a standard, and they thanked him for it. That is integrity in practice."
      },
      {
        "id": "v3",
        "name": "Kyle Malone",
        "value": "Innovation",
        "dept": "Graffix",
        "deptKey": "graffix",
        "role": "Motion Designer",
        "quote": "Kyle proposed and shipped our first motion-design system, then taught the rest of the studio how to use it. The work he did this year will outlive his time here — the highest bar for innovation."
      },
      {
        "id": "v4",
        "name": "Asaya Azah",
        "value": "Community",
        "dept": "Cross Cultural Centers",
        "deptKey": "ccc",
        "role": "GSRC Peer Educator",
        "quote": "Asaya creates rooms where people actually exhale. Whether it is GSRC drop-in hours or the Cultural Grads ceremony, she sees who is on the edge of the conversation and pulls them in. That is community work."
      },
      {
        "id": "v5",
        "name": "Devon Trinh",
        "value": "Fun",
        "dept": "Recreation",
        "deptKey": "recreation",
        "role": "Game Room Lead",
        "quote": "Devon turned a Friday-afternoon shift into something students plan their week around. His tournaments, themed nights, and unrepentant trash talk are the reason the third floor sounds like a real college."
      },
      {
        "id": "v6",
        "name": "Savana Coleman",
        "value": "Connection",
        "dept": "Cross Cultural Centers",
        "deptKey": "ccc",
        "role": "Cultural Grads Lead",
        "quote": "Savana remembers the names. She remembers the majors. She remembers what someone said three weeks ago and asks how it is going. The trust she builds is the reason students keep coming back."
      }
    ],
    "staffWinners": [
      {
        "id": "s1",
        "name": "Dr. Renee Castillo",
        "dept": "Center for Student Involvement",
        "deptKey": "csi",
        "role": "Director, Student Engagement",
        "quote": "Renee mentors the people who mentor our students. The leadership pipeline she has built across CSI — from peer educators to professional staff — is one of the most important pieces of work happening at the U-SU, and most of it is invisible until it isn’t."
      },
      {
        "id": "s2",
        "name": "James Okonkwo",
        "dept": "Operations",
        "deptKey": "operations",
        "role": "Director, Facilities & Reservations",
        "quote": "James has spent twelve years making sure the lights, the rooms, and the people who run them are ready for whatever campus throws at us. When students say \"the U-SU just works,\" they are describing James’s work without knowing it."
      }
    ]
  },
